Dialogue: 0,0:00:11.54,0:00:17.14,romaji,,0,0,0,,anemoi opening full 『Eternicle (エタニクル)』 by ASCA
Dialogue: 0,0:00:15.54,0:00:17.14,vietsub,,0,0,0,,Vietsub: Kull
Dialogue: 0,0:00:17.99,0:00:23.30,romaji,,0,0,0,,mabayuku yureru sougen o
Dialogue: 0,0:00:23.30,0:00:30.99,romaji,,0,0,0,,inochi no uta da to oshiete kureta kimi wa
Dialogue: 0,0:00:30.99,0:00:39.50,romaji,,0,0,0,,namae o yonda koto sae mo kizukanai kurai ni
Dialogue: 0,0:00:39.50,0:00:44.19,romaji,,0,0,0,,tooku o mitsumete ita
Dialogue: 0,0:00:44.19,0:00:50.75,romaji,,0,0,0,,sasayakana negai mo kaze ni madoi tsuzukete
Dialogue: 0,0:00:50.75,0:00:58.91,romaji,,0,0,0,,boku wa oikoshite iku hoshi no matataki o sagashiteta
Dialogue: 0,0:00:58.91,0:01:05.81,romaji,,0,0,0,,zutto dakishimete ita ikutsumo no kotoba ga
Dialogue: 0,0:01:05.81,0:01:12.61,romaji,,0,0,0,,tasogare ni kieta to shite mo soba ni iru yo
Dialogue: 0,0:01:12.61,0:01:19.92,romaji,,0,0,0,,hitotsuzutsu moji o wasurezu narabete matsu kara
Dialogue: 0,0:01:19.92,0:01:28.84,romaji,,0,0,0,,ikuoku no hate yakusoku wa kaze no naka ni
Dialogue: 0,0:01:39.47,0:01:44.62,romaji,,0,0,0,,tokei no hari ga ayumidashi
Dialogue: 0,0:01:44.62,0:01:52.26,romaji,,0,0,0,,utsuriyuku kisetsu ga bokura no hoo o nadeta
Dialogue: 0,0:01:52.62,0:01:59.18,romaji,,0,0,0,,kazaguruma no hane mawasu kaze ni kokoro odorase
Dialogue: 0,0:01:59.18,0:02:07.61,romaji,,0,0,0,,konjiki no unabara de ima mo mimi o sumasetsuzuketa
Dialogue: 0,0:02:07.61,0:02:14.42,romaji,,0,0,0,,moshi dakishimetakatta natsukashii sugata o
Dialogue: 0,0:02:14.42,0:02:21.14,romaji,,0,0,0,,akatsuki ni mitsukeraretara hashiridasu yo
Dialogue: 0,0:02:21.14,0:02:28.56,romaji,,0,0,0,,chiisana te o tori namida o koraeta egao de
Dialogue: 0,0:02:28.56,0:02:37.76,romaji,,0,0,0,,seisou o koe yakusoku wa kaze to tomo ni
Dialogue: 0,0:03:01.26,0:03:07.36,romaji,,0,0,0,,kaze wa yasashiku yorisoi tsuzuketa
Dialogue: 0,0:03:07.36,0:03:16.20,romaji,,0,0,0,,dakedo tonari ni tatsu kimi dake ga mada tookute
Dialogue: 0,0:03:16.20,0:03:22.82,romaji,,0,0,0,,zutto dakishimete ita ikutsumo no kotoba ga
Dialogue: 0,0:03:22.82,0:03:29.74,romaji,,0,0,0,,tasogare ni kieta to shite mo soba ni ita yo
Dialogue: 0,0:03:29.74,0:03:36.99,romaji,,0,0,0,,kimi ga kasaneteta mugen no moji ni tadoritsuku
Dialogue: 0,0:03:36.99,0:03:49.84,romaji,,0,0,0,,tokoshie no sora o koe tsumugu kimi to boku no yakusoku
Dialogue: 0,0:03:49.84,0:03:52.84,romaji,,0,0,0,,
Dialogue: 0,0:00:17.99,0:00:23.30,kanji,,0,0,0,,まばゆく揺れる草原を
Dialogue: 0,0:00:23.30,0:00:30.99,kanji,,0,0,0,,生命の歌だと教えてくれた君は
Dialogue: 0,0:00:30.99,0:00:39.50,kanji,,0,0,0,,名前を呼んだことさえも 気づかないくらいに
Dialogue: 0,0:00:39.50,0:00:44.19,kanji,,0,0,0,,遠くを見つめていた
Dialogue: 0,0:00:44.19,0:00:50.75,kanji,,0,0,0,,ささやかな願いも風に惑い続けて
Dialogue: 0,0:00:50.75,0:00:58.91,kanji,,0,0,0,,僕は追い越していく星の瞬きを探してた
Dialogue: 0,0:00:58.91,0:01:05.81,kanji,,0,0,0,,ずっと抱き締めていた いくつもの言葉が
Dialogue: 0,0:01:05.81,0:01:12.61,kanji,,0,0,0,,黄昏に消えたとしても そばにいるよ
Dialogue: 0,0:01:12.61,0:01:19.92,kanji,,0,0,0,,ひとつずつ文字を 忘れず並べて待つから
Dialogue: 0,0:01:19.92,0:01:28.84,kanji,,0,0,0,,幾億の果て 約束は風の中に
Dialogue: 0,0:01:39.47,0:01:44.62,kanji,,0,0,0,,時計の針が歩みだし
Dialogue: 0,0:01:44.62,0:01:52.26,kanji,,0,0,0,,移りゆく季節が僕らの頬を撫でた
Dialogue: 0,0:01:52.62,0:01:59.18,kanji,,0,0,0,,風車の羽回す風に心踊らせ
Dialogue: 0,0:01:59.18,0:02:07.61,kanji,,0,0,0,,金色の海原で今も耳を澄ませ続けた
Dialogue: 0,0:02:07.61,0:02:14.42,kanji,,0,0,0,,もし抱き締めたかった懐かしい姿を
Dialogue: 0,0:02:14.42,0:02:21.14,kanji,,0,0,0,,暁に見つけられたら 走りだすよ
Dialogue: 0,0:02:21.14,0:02:28.56,kanji,,0,0,0,,小さな手をとり 涙を堪えた笑顔で
Dialogue: 0,0:02:28.56,0:02:37.76,kanji,,0,0,0,,星霜を越え 約束は風と共に
Dialogue: 0,0:03:01.26,0:03:07.36,kanji,,0,0,0,,風は優しく寄り添い続けた
Dialogue: 0,0:03:07.36,0:03:16.20,kanji,,0,0,0,,だけど隣に立つ 君だけがまだ遠くて
Dialogue: 0,0:03:16.20,0:03:22.82,kanji,,0,0,0,,ずっと抱き締めていた いくつもの言葉が
Dialogue: 0,0:03:22.82,0:03:29.74,kanji,,0,0,0,,黄昏に消えたとしても そばにいたよ
Dialogue: 0,0:03:29.74,0:03:36.99,kanji,,0,0,0,,君が重ねてた夢幻の文字に辿り着く
Dialogue: 0,0:03:36.99,0:03:49.84,kanji,,0,0,0,,永久の空を越え 紡ぐ君と僕の約束
Dialogue: 0,0:03:49.84,0:03:52.84,kanji,,0,0,0,,
Dialogue: 0,0:00:17.99,0:00:23.30,vietsub,,0,0,0,,Cánh đồng đung đưa, dưới ánh nắng rực rỡ kia,
Dialogue: 0,0:00:23.30,0:00:30.99,vietsub,,0,0,0,,là khúc ca sinh mệnh, chính người từng dạy cho tôi.
Dialogue: 0,0:00:30.99,0:00:39.50,vietsub,,0,0,0,,Người chẳng hề nhận ra rằng tôi đã khẽ gọi tên người,
Dialogue: 0,0:00:39.50,0:00:44.19,vietsub,,0,0,0,,mà cứ nhìn về một chốn xa xăm.
Dialogue: 0,0:00:44.19,0:00:50.75,vietsub,,0,0,0,,Đem những mong ước nhỏ nhoi cuốn theo chiều gió,
Dialogue: 0,0:00:50.75,0:00:58.91,vietsub,,0,0,0,,tôi mải miết đi tìm, một ánh sao lấp lánh trên bầu trời, bất chợt thoáng qua.
Dialogue: 0,0:00:58.91,0:01:05.81,vietsub,,0,0,0,,Muôn ngàn lời yêu thương, tôi hằng ôm ấp trong tim...
Dialogue: 0,0:01:05.81,0:01:12.61,vietsub,,0,0,0,,dẫu rồi tất cả sẽ, tan biến dưới ánh chiều tà, vẫn sẽ luôn, ở bên người.
Dialogue: 0,0:01:12.61,0:01:19.92,vietsub,,0,0,0,,Tôi sẽ viết ra từng câu chữ, để không quên đi, mà lặng lẽ đợi chờ.
Dialogue: 0,0:01:19.92,0:01:28.84,vietsub,,0,0,0,,Đến nơi tận cùng năm tháng, ước hẹn đôi ta... vẫn theo chiều gió cuốn.
Dialogue: 0,0:01:39.47,0:01:44.62,vietsub,,0,0,0,,Kim đồng hồ bắt đầu nhích từng nhịp.
Dialogue: 0,0:01:44.62,0:01:52.26,vietsub,,0,0,0,,Bốn mùa cây thay lá, cứ thế trôi qua, khẽ vuốt ve gò má hai ta.
Dialogue: 0,0:01:52.62,0:01:59.18,vietsub,,0,0,0,,Ngọn gió xoay cánh cối xay gió làm trái tim tôi rộn ràng.
Dialogue: 0,0:01:59.18,0:02:07.61,vietsub,,0,0,0,,Giữa biển lúa chín vàng, đến bây giờ tôi vẫn trân trọng lắng nghe.
Dialogue: 0,0:02:07.61,0:02:14.42,vietsub,,0,0,0,,Nếu như bóng hình thân thương, tôi hằng khát khao được ôm lấy...
Dialogue: 0,0:02:14.42,0:02:21.14,vietsub,,0,0,0,,có thể tìm lại dưới ánh bình minh này, tôi sẽ lao đến ngay.
Dialogue: 0,0:02:21.14,0:02:28.56,vietsub,,0,0,0,,Rồi tôi sẽ nắm bàn tay nhỏ bé ấy, mỉm cười để giấu đi những giọt lệ.
Dialogue: 0,0:02:28.56,0:02:37.76,vietsub,,0,0,0,,Vượt qua tháng năm trôi, ước hẹn đôi ta... vẫn theo chiều gió cuốn.
Dialogue: 0,0:03:01.26,0:03:07.36,vietsub,,0,0,0,,Làn gió vẫn luôn dịu dàng bao bọc lấy tôi.
Dialogue: 0,0:03:07.36,0:03:16.20,vietsub,,0,0,0,,Nhưng chỉ riêng người lẽ ra phải bên cạnh tôi, lại quá xa vời.
Dialogue: 0,0:03:16.20,0:03:22.82,vietsub,,0,0,0,,Muôn ngàn lời yêu thương, tôi hằng ôm ấp trong tim...
Dialogue: 0,0:03:22.82,0:03:29.74,vietsub,,0,0,0,,dẫu rồi tất cả sẽ, tan biến dưới ánh chiều tà, đã luôn mãi, ở bên người.
Dialogue: 0,0:03:29.74,0:03:36.99,vietsub,,0,0,0,,Tôi sẽ chạm đến những dòng chữ tựa như giấc mơ người đã chất chồng.
Dialogue: 0,0:03:36.99,0:03:49.84,vietsub,,0,0,0,,Vượt qua bầu trời vô tận này, dệt nên lời hẹn ước, của người và tôi.
Dialogue: 0,0:03:49.84,0:03:52.84,vietsub,,0,0,0,,
