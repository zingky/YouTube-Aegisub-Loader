Dialogue: 0,0:00:24.89,0:00:29.39,vietsub - chung,,0,0,0,,Giọt mồ hôi lấp lánh, chiếc áo thun, tình yêu chợt đến.
Dialogue: 0,0:00:30.34,0:00:35.56,vietsub - chung,,0,0,0,,Ngắm nhìn cậu tỏa sáng rực rỡ hơn bất cứ ai.
Dialogue: 0,0:00:35.98,0:00:40.62,vietsub - chung,,0,0,0,,Tớ đã tìm thấy cảm xúc rung động đầu đời.
Dialogue: 0,0:00:41.61,0:00:46.94,vietsub - chung,,0,0,0,,Một hành trình mới bắt đầu từ đây.
Dialogue: 0,0:00:47.26,0:00:51.78,vietsub - chung,,0,0,0,,Sau cơn mưa, bất chợt thổi qua, làn gió xanh.
Dialogue: 0,0:00:52.64,0:00:58.12,vietsub - chung,,0,0,0,,Ngày nào đó tớ sẽ vượt qua ánh nắng chói chang kia.
Dialogue: 0,0:00:58.12,0:01:03.83,vietsub - chung,,0,0,0,,Từ giờ tớ sẽ vẽ nên sắc màu tình yêu.
Dialogue: 0,0:01:03.83,0:01:09.22,vietsub - chung,,0,0,0,,Điểm tô cho trang đầu tiên của chúng ta.
Dialogue: 0,0:01:09.46,0:01:15.03,vietsub - chung,,0,0,0,,Trên tạp chí bói toán, có 2 vì sao lấp lánh...
Dialogue: 0,0:01:15.03,0:01:20.63,vietsub - chung,,0,0,0,,tớ thử đặt tương lai của 2 ta vào đó.
Dialogue: 0,0:01:20.63,0:01:26.11,vietsub - chung,,0,0,0,,Con tim hằn bao vết sẹo, chẳng thể nào xóa nhoà...
Dialogue: 0,0:01:26.11,0:01:31.17,vietsub - chung,,0,0,0,,Sự dịu dàng của cậu chữa lành tất cả.
Dialogue: 0,0:01:31.17,0:01:34.13,vietsub - chung,,0,0,0,,Chẳng biết từ khi nào, khoảng trống mở ra.
Dialogue: 0,0:01:34.13,0:01:37.46,vietsub - chung,,0,0,0,,Con tim tớ dần được lấp đầy,
Dialogue: 0,0:01:37.46,0:01:42.39,vietsub - chung,,0,0,0,,bằng những cử chỉ tự nhiên bất chợt thoáng qua...
Dialogue: 0,0:01:42.39,0:01:45.29,vietsub - chung,,0,0,0,,Rồi một ngày nào đó, khi cậu kể về ước mơ.
Dialogue: 0,0:01:45.29,0:01:48.57,vietsub - chung,,0,0,0,,Khuôn mặt thân thương ấy,
Dialogue: 0,0:01:48.57,0:01:54.19,vietsub - chung,,0,0,0,,tớ muốn mãi ngắm nhìn, muốn cậu mãi mỉm cười.
Dialogue: 0,0:02:05.27,0:02:10.13,vietsub - chung,,0,0,0,,Khi muốn bảo vệ điều gì đó quan trọng,
Dialogue: 0,0:02:10.76,0:02:16.17,vietsub - chung,,0,0,0,,nếu mỗi bước chân cần mang dũng khí...
Dialogue: 0,0:02:16.39,0:02:21.75,vietsub - chung,,0,0,0,,Tớ đã trốn chạy khỏi những tổn thương,
Dialogue: 0,0:02:22.00,0:02:27.34,vietsub - chung,,0,0,0,,lúc nào cũng chỉ lẩn tránh mà thôi.
Dialogue: 0,0:02:27.51,0:02:33.14,vietsub - chung,,0,0,0,,Thói quen tỏ ra mạnh mẽ, giờ đây chẳng biết giấu vào đâu.
Dialogue: 0,0:02:33.14,0:02:38.50,vietsub - chung,,0,0,0,,Tớ bối rối lạc lõng, ngay trong tim mình.
Dialogue: 0,0:02:38.68,0:02:44.07,vietsub - chung,,0,0,0,,Lần đầu tớ nhận ra, tình cảm chân thành từ cậu...
Dialogue: 0,0:02:44.18,0:02:49.20,vietsub - chung,,0,0,0,,Nước mắt tuôn rơi thay ngàn lời muốn nói...
Dialogue: 0,0:02:49.20,0:02:52.23,vietsub - chung,,0,0,0,,Dẫu sải bước đôi ta, có chút khác biệt...
Dialogue: 0,0:02:52.23,0:02:55.50,vietsub - chung,,0,0,0,,Từng bước hãy đi cùng nhau cậu nhé.
Dialogue: 0,0:02:55.50,0:03:00.63,vietsub - chung,,0,0,0,,Dù con đường chúng ta đi, có thể gặp ngàn chông gai.
Dialogue: 0,0:03:00.63,0:03:03.27,vietsub - chung,,0,0,0,,Trên bản đồ trắng tinh, được gấp làm đôi...
Dialogue: 0,0:03:03.27,0:03:06.42,vietsub - chung,,0,0,0,,Tớ viết lên một quyết tâm nhỏ bé.
Dialogue: 0,0:03:06.60,0:03:12.57,vietsub - chung,,0,0,0,,Lúc này tớ sẽ thật lòng nói ra.
Dialogue: 0,0:03:35.14,0:03:40.54,vietsub - chung,,0,0,0,,Bên tai tớ vang vọng, giai điệu chỉ dành cho hai ta.
Dialogue: 0,0:03:40.86,0:03:45.64,vietsub - chung,,0,0,0,,Cố kìm nén, những giọt nước mắt trào dâng.
Dialogue: 0,0:03:46.48,0:03:51.06,vietsub - chung,,0,0,0,,Tớ sẽ nói với cậu, những lời giản đơn thôi...
Dialogue: 0,0:03:51.29,0:03:56.44,vietsub - chung,,0,0,0,,"Từ nay về sau hãy luôn bên nhau, cậu nhé..."
Dialogue: 0,0:03:56.44,0:03:59.21,vietsub - chung,,0,0,0,,Cảm xúc này, chẳng thể kìm nén...
Dialogue: 0,0:03:59.21,0:04:02.53,vietsub - chung,,0,0,0,,Từ bầu trời lúc 25 giờ diệu kỳ...
Dialogue: 0,0:04:02.53,0:04:05.32,vietsub - chung,,0,0,0,,Tựa giọt sương long lanh thuần khiết...
Dialogue: 0,0:04:05.32,0:04:07.39,vietsub - chung,,0,0,0,,tình yêu rơi vào tim tớ.
Dialogue: 0,0:04:07.39,0:04:10.27,vietsub - chung,,0,0,0,,Và rồi tớ chợt nhận ra, sâu thẳm trong tim.
Dialogue: 0,0:04:10.27,0:04:13.74,vietsub - chung,,0,0,0,,Một làn gió dịu dàng đang thổi qua.
Dialogue: 0,0:04:13.74,0:04:18.63,vietsub - chung,,0,0,0,,Cánh cửa đến ngày mai, nhẹ nhàng mở ra...
Dialogue: 0,0:04:18.63,0:04:21.45,vietsub - chung,,0,0,0,,Câu từ lúc này sẽ, vượt qua thời gian,
Dialogue: 0,0:04:21.45,0:04:24.64,vietsub - chung,,0,0,0,,thẳng đến nơi vĩnh hằng...
Dialogue: 0,0:04:24.79,0:04:29.81,vietsub - chung,,0,0,0,,Chúng ta đã trải qua biết bao mùa cây thay lá.
Dialogue: 0,0:04:29.81,0:04:32.63,vietsub - chung,,0,0,0,,Để rồi ta đã tìm thấy bến đỗ bình yên,
Dialogue: 0,0:04:32.63,0:04:36.00,vietsub - chung,,0,0,0,,sau một hành trình dài thật dài.
Dialogue: 0,0:04:36.00,0:04:41.54,vietsub - chung,,0,0,0,,Hãy vun đắp tình yêu, ta đã nguyện thề.
Dialogue: 0,0:04:36.88,0:04:42.56,Credit,,0,0,0,,Thanks for Watching !!!
