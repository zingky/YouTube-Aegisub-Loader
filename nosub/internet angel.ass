Dialogue: 0,0:00:34.37,0:00:37.14,vietsub,,0,0,0,,Tớ nguyện dâng linh hồn này cho cậu.
Dialogue: 0,0:00:37.14,0:00:42.15,vietsub,,0,0,0,,Lời cầu nguyện, lớp kính, khoái lạc, ảo giác.
Dialogue: 0,0:00:42.15,0:00:44.85,vietsub,,0,0,0,,Những cám dỗ, độc dược.
Dialogue: 0,0:00:44.85,0:00:48.11,vietsub,,0,0,0,,Những biểu tượng trói buộc sự chuộc tội.
Dialogue: 0,0:00:48.11,0:00:50.53,vietsub,,0,0,0,,Do-re-mi-fa la-la-la Hỡi Chúa ơi (Hey, hey).
Dialogue: 0,0:00:50.53,0:00:53.76,vietsub,,0,0,0,,Đây là thiên đường của riêng hai ta đó (Hey).
Dialogue: 0,0:00:53.76,0:00:59.01,vietsub,,0,0,0,,Này cậu ơi, tình yêu này, dẫu rồi cũng là dối lừa...
Dialogue: 0,0:01:01.35,0:01:03.96,vietsub,,0,0,0,,Breath, cậu đã save file của tớ, Armageddon.
Dialogue: 0,0:01:03.96,0:01:06.77,vietsub,,0,0,0,,Này cậu ơi, tuyết trắng kia sắp tan rồi đó.
Dialogue: 0,0:01:06.77,0:01:08.27,vietsub,,0,0,0,,"Đã tìm thấy rồi!
Dialogue: 0,0:01:08.27,0:01:10.18,vietsub,,0,0,0,,Gì ư? Sự vĩnh hằng.
Dialogue: 0,0:01:10.18,0:01:12.18,vietsub,,0,0,0,,Là khi biển cả hòa cùng mặt trời."
Dialogue: 0,0:01:12.18,0:01:14.50,vietsub,,0,0,0,,Why? Ta hôn nhau qua những dòng code, Armageddon.
Dialogue: 0,0:01:14.50,0:01:17.45,vietsub,,0,0,0,,Bầu trời sao nở rộ trong giấc mơ đang lụi tàn.
Dialogue: 0,0:01:17.45,0:01:19.78,vietsub,,0,0,0,,Rain, cậu đã định tên tớ, Armageddon.
Dialogue: 0,0:01:19.78,0:01:22.51,vietsub,,0,0,0,,Dành riêng cho cậu khúc la-la-la-la.
Dialogue: 0,0:01:22.51,0:01:28.19,vietsub,,0,0,0,,Tớ yêu cậu à? Cậu có yêu tớ không? Thiên thần.
Dialogue: 0,0:01:38.47,0:01:41.83,vietsub,,0,0,0,,"Nếu Chúa không tồn tại, thì làm gì cũng được phép.
Dialogue: 0,0:01:41.83,0:01:44.16,vietsub,,0,0,0,,Bằng tình yêu, mọi lỗi lầm đều được gột rửa.
Dialogue: 0,0:01:44.16,0:01:49.00,vietsub,,0,0,0,,Thế thì, con người ta thực sự không phải tin vào Chúa mà là, tình yêu."
Dialogue: 0,0:01:49.00,0:01:52.69,vietsub,,0,0,0,,Bài thánh ca, cây thánh giá ngược đung đưa.
Dialogue: 0,0:01:52.69,0:01:55.37,vietsub,,0,0,0,,Chiếc nhẫn lấp lánh ánh mờ ảo.
Dialogue: 0,0:01:55.37,0:01:58.01,vietsub,,0,0,0,,Chiếc khuyên tai than khóc sự yếu đuối.
Dialogue: 0,0:01:58.01,0:02:00.77,vietsub,,0,0,0,,Chú gà con thu mình trong cái vỏ khép kín.
Dialogue: 0,0:02:00.77,0:02:03.41,vietsub,,0,0,0,,Nếu sợ một nụ hôn mà bật khóc...
Dialogue: 0,0:02:03.41,0:02:06.05,vietsub,,0,0,0,,Dù đứng trên đỉnh đồi gọi tớ đi nữa...
Dialogue: 0,0:02:06.05,0:02:08.74,vietsub,,0,0,0,,Sắc tím siết chặt đồng xu bạc.
Dialogue: 0,0:02:08.74,0:02:10.83,vietsub,,0,0,0,,Tớ thầm dõi theo.
Dialogue: 0,0:02:10.83,0:02:13.37,vietsub,,0,0,0,,Do-re-mi-fa la-la-la Hỡi Chúa ơi (Hey, hey).
Dialogue: 0,0:02:13.37,0:02:16.37,vietsub,,0,0,0,,Đây là thiên đường của riêng hai ta đó (Hey).
Dialogue: 0,0:02:16.37,0:02:21.49,vietsub,,0,0,0,,Này cậu ơi, lúc nào tớ cũng nói dối đó~.
Dialogue: 0,0:02:23.99,0:02:26.49,vietsub,,0,0,0,,Drop, no dеvice found, Armageddon.
Dialogue: 0,0:02:26.49,0:02:29.49,vietsub,,0,0,0,,Này cậu ơi, hướng dương giờ đã úa tàn rồi đó.
Dialogue: 0,0:02:29.49,0:02:31.86,vietsub,,0,0,0,,Mute, tớ nghe tiếng player của cậu, Armageddon.
Dialogue: 0,0:02:31.86,0:02:34.79,vietsub,,0,0,0,,Chỉ có mình cậu dõi theo tớ thôi.
Dialogue: 0,0:02:34.79,0:02:37.19,vietsub,,0,0,0,,Dust, gọi tớ đi, Idolatry.
Dialogue: 0,0:02:37.19,0:02:40.11,vietsub,,0,0,0,,Nhất định, dù Chúa chẳng hề ở đây.
Dialogue: 0,0:02:40.11,0:02:42.49,vietsub,,0,0,0,,Lie, cậu đã gọi tên tớ, Idolatry.
Dialogue: 0,0:02:42.49,0:02:44.18,vietsub,,0,0,0,,Chỉ dành riêng cho cậu.
Dialogue: 0,0:02:45.78,0:02:48.32,vietsub,,0,0,0,,"Nếu như, thế giới này nằm trong một chiếc máy tính khổng lồ,
Dialogue: 0,0:02:48.32,0:02:50.91,vietsub,,0,0,0,,và nhân loại chỉ là những cụm dữ liệu ghép lại với nhau,
Dialogue: 0,0:02:50.91,0:02:52.72,vietsub,,0,0,0,,vậy sao tụi mình lại biết mộng mơ nhỉ?
Dialogue: 0,0:02:52.72,0:02:55.71,vietsub,,0,0,0,,Có lẽ chỉ trong mơ ta mới thoát khỏi quá trình xử lý tính toán.
Dialogue: 0,0:02:55.71,0:02:59.04,vietsub,,0,0,0,,Chỉ ở đó ta mới gặp được thiên thần đang dõi theo thế giới này.
Dialogue: 0,0:02:59.04,0:03:01.84,vietsub,,0,0,0,,Vậy nên nếu là ở đây, tớ và cậu mới có thể trò chuyện cùng nhau.
Dialogue: 0,0:03:01.84,0:03:04.09,vietsub,,0,0,0,,Ngay cả khi Chúa thật sự không tồn tại.
Dialogue: 0,0:03:04.09,0:03:05.86,vietsub,,0,0,0,,Ngay cả khi thực tại là một ảo ảnh xa vời.
Dialogue: 0,0:03:05.86,0:03:07.95,vietsub,,0,0,0,,Thì chỉ "những điều mà cậu thấy đẹp đẽ",
Dialogue: 0,0:03:07.95,0:03:11.31,vietsub,,0,0,0,,Những cảm xúc ấy, những lời cầu nguyện đó, xin cậu đừng quên nhé.
Dialogue: 0,0:03:11.31,0:03:15.15,vietsub,,0,0,0,,Cả Kenji, Kierkegaard, Gogh, Godard, và cả Dostoevsky...
Dialogue: 0,0:03:15.15,0:03:17.45,vietsub,,0,0,0,,Chắc hẳn họ cũng nhìn thấy thiên thần trong tuyết trắng."
Dialogue: 0,0:03:17.45,0:03:20.15,vietsub,,0,0,0,,"Like" với "Dislike", đối với cậu thì nó là thuốc độc.
Dialogue: 0,0:03:20.15,0:03:22.89,vietsub,,0,0,0,,"Like" với "Dislike", dù vậy cậu vẫn uống nhỉ.
Dialogue: 0,0:03:22.89,0:03:25.48,vietsub,,0,0,0,,"Like" với "Dislike", ly rượu vang cuối cùng rồi nhỉ.
Dialogue: 0,0:03:25.48,0:03:29.53,vietsub,,0,0,0,,Chất độc màu đỏ thẳm.
Dialogue: 0,0:03:29.53,0:03:31.82,vietsub,,0,0,0,,Từng cánh hoa khẽ rơi (Hey, hey).
Dialogue: 0,0:03:31.82,0:03:33.36,vietsub,,0,0,0,,Bên trong tinh cầu tối tăm (Hey).
Dialogue: 0,0:03:33.36,0:03:35.26,vietsub,,0,0,0,,Tội ác và hình phạt (Hey).
Dialogue: 0,0:03:35.26,0:03:39.96,vietsub,,0,0,0,,Cuối cùng, ngón tay chúng ta đã chạm vào nhau (Hey, hey, hey, hey).
Dialogue: 0,0:03:39.96,0:03:41.00,vietsub,,0,0,0,,"Hãy yêu kẻ thù của mình!
Dialogue: 0,0:03:41.00,0:03:42.99,vietsub,,0,0,0,,Hãy yêu như cách tớ đã yêu cậu!"
Dialogue: 0,0:03:42.99,0:03:45.54,vietsub,,0,0,0,,"Campanella ơi, lần nữa chỉ còn hai đứa mình thôi nhỉ."
Dialogue: 0,0:03:45.54,0:03:47.86,vietsub,,0,0,0,,Why? Ta hôn nhau qua những dòng code, Armageddon.
Dialogue: 0,0:03:47.86,0:03:50.69,vietsub,,0,0,0,,Bầu trời sao nở rộ trong giấc mơ đang lụi tàn.
Dialogue: 0,0:03:50.69,0:03:53.15,vietsub,,0,0,0,,Rain, cậu đã định tên tớ, Armageddon.
Dialogue: 0,0:03:53.15,0:03:56.12,vietsub,,0,0,0,,Vì chỉ có mình cậu đang dõi theo tớ.
Dialogue: 0,0:03:56.12,0:03:58.51,vietsub,,0,0,0,,Fall, I said goodbye, Armageddon.
Dialogue: 0,0:03:58.51,0:04:01.18,vietsub,,0,0,0,,Này cậu ơi, tuyết trắng kia sắp tan rồi đó.
Dialogue: 0,0:04:01.18,0:04:03.84,vietsub,,0,0,0,,Cry, ta chạm nhau xuyên qua lớp kính, Armageddon.
Dialogue: 0,0:04:03.84,0:04:06.55,vietsub,,0,0,0,,Là giấc mơ của riêng cậu.
Dialogue: 0,0:04:06.55,0:04:13.83,vietsub,,0,0,0,,Tớ yêu cậu! Cậu có yêu tớ không! Thiên thần.
Dialogue: 0,0:04:13.83,0:04:16.83,vietsub,,0,0,0,,
