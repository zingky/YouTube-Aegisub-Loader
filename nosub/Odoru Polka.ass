Dialogue: 0,0:00:00.45,0:00:02.25,vietsub,,0,0,0,,(DADADA DANCE! DADADA DANCE!)
Dialogue: 0,0:00:02.25,0:00:03.96,vietsub,,0,0,0,,Rê rê mi fa fa fa mi rê
Dialogue: 0,0:00:04.07,0:00:05.75,vietsub,,0,0,0,,(DADADA DANCE! DADADA DANCE!)
Dialogue: 0,0:00:05.75,0:00:07.82,vietsub,,0,0,0,,Cứ giao hết cho tớ!
Dialogue: 0,0:00:09.17,0:00:12.43,vietsub,,0,0,0,,Yeahhhhhhh! Bắt-đầu-thôi-nào!
Dialogue: 0,0:00:12.43,0:00:15.95,vietsub,,0,0,0,,Ngày nào cũng toàn chuyện vui thì chẳng có đâu (Không đâu!)
Dialogue: 0,0:00:15.95,0:00:19.25,vietsub,,0,0,0,,Những lúc như thế thì lại đây nhảy cùng tớ (Yeah yeah)
Dialogue: 0,0:00:19.45,0:00:22.85,vietsub,,0,0,0,,Tớ vừa thấy một cảnh tuyệt lắm luôn đó (Nè nè)
Dialogue: 0,0:00:22.85,0:00:26.35,vietsub,,0,0,0,,Chờ chút nha, tớ muốn cho ai đó xem liền luôn.
Dialogue: 0,0:00:26.35,0:00:29.25,vietsub,,0,0,0,,(DADADA DANCE! DADADA DANCE! DADADA DA DANCE!)
Dialogue: 0,0:00:29.76,0:00:32.74,vietsub,,0,0,0,,Dù trăm lần đi nữa thì cậu vẫn là độc nhất vô nhị.
Dialogue: 0,0:00:32.85,0:00:36.20,vietsub,,0,0,0,,Hãy cứ nhảy theo nhịp điệu giỏi nhất của mỗi người.
Dialogue: 0,0:00:36.20,0:00:37.85,vietsub,,0,0,0,,Un, deux, trois or Three, Two, One.
Dialogue: 0,0:00:37.85,0:00:43.45,vietsub,,0,0,0,,Nhảy kiểu nào cũng được, miễn cậu đừng quên đi nụ cười của mình (Niko)
Dialogue: 0,0:00:43.45,0:00:50.25,vietsub,,0,0,0,,Tạm thời thì cậu cứ tham gia với tớ và cháy hết mình hôm nay (Enjoy)
Dialogue: 0,0:00:50.25,0:00:53.50,vietsub,,0,0,0,,Nghĩ ngợi sâu xa làm gì cho phức tạp.
Dialogue: 0,0:00:53.74,0:01:00.45,vietsub,,0,0,0,,Hãy đến đây nào, mau nhảy vào đi, Oh Yeah! (Một, hai, ba)
Dialogue: 0,0:01:00.64,0:01:03.94,vietsub,,0,0,0,,Mọi người đông đủ cả rồi, cảm giác thật vui quá xá!
Dialogue: 0,0:01:03.94,0:01:07.55,vietsub,,0,0,0,,Chuyện này chuyện nọ rồi sẽ ổn hết thôi cậu ơi, All OK!
Dialogue: 0,0:01:07.55,0:01:08.98,vietsub,,0,0,0,,Nào, nhảy lên, nhảy lên nào.
Dialogue: 0,0:01:08.98,0:01:10.82,vietsub,,0,0,0,,Lỡ thất bại cũng đừng có để ý.
Dialogue: 0,0:01:10.85,0:01:14.66,vietsub,,0,0,0,,Thời khắc toả sáng này là sân khấu của cậu.
Dialogue: 0,0:01:17.33,0:01:21.22,vietsub,,0,0,0,,Có những lúc buồn chán đến nản lòng luôn ấy (Buồn)
Dialogue: 0,0:01:21.22,0:01:24.65,vietsub,,0,0,0,,Cứ gác nó sang một bên rồi nhảy cùng tớ đi! (Let's dance)
Dialogue: 0,0:01:24.65,0:01:28.06,vietsub,,0,0,0,,Cố gắng lúc nào muốn cố gắng là được rồi (Fight)
Dialogue: 0,0:01:28.06,0:01:31.50,vietsub,,0,0,0,,Ah~ Tự do như là cơn gió thoáng qua vậy nhỉ (Vèooo)
Dialogue: 0,0:01:31.50,0:01:38.32,vietsub,,0,0,0,,Chưa có gì trong tay thì tạo ra là xong, như những gì mình mơ (Yeah Yeah)
Dialogue: 0,0:01:38.32,0:01:41.45,vietsub,,0,0,0,,Dù là truyền thuyết thì cũng có khởi đầu mà.
Dialogue: 0,0:01:41.65,0:01:44.71,vietsub,,0,0,0,,Làm được không ta? Tớ chẳng biết đâu!
Dialogue: 0,0:01:45.10,0:01:48.58,vietsub,,0,0,0,,Dù chùn bước một chút, lần tới tuyệt đối sẽ ổn thôi!
Dialogue: 0,0:01:48.58,0:01:52.05,vietsub,,0,0,0,,Dù thất bại thì ta vẫn còn sống nên vẫn là OK !
Dialogue: 0,0:01:52.05,0:01:53.70,vietsub,,0,0,0,,Nào, nhảy lên, nhảy lên nào.
Dialogue: 0,0:01:53.70,0:01:55.50,vietsub,,0,0,0,,Còn nếu mà thắng thì siêu may mắn.
Dialogue: 0,0:01:55.50,0:01:58.91,vietsub,,0,0,0,,Vui hơn nữa nào, ngày mai ta tiến lên nào.
Dialogue: 0,0:02:05.29,0:02:11.65,vietsub,,0,0,0,,Run-ta-ta run-ta-ta, chỉ là muốn mãi yêu lấy những điều mình thích.
Dialogue: 0,0:02:11.74,0:02:18.35,vietsub,,0,0,0,,Run-ta-ta run-ta-ta, cứ chầm chậm đung đưa theo nhịp điệu la la.
Dialogue: 0,0:02:18.35,0:02:24.65,vietsub,,0,0,0,,Run-ta-ta run-ta-ta, thỉnh thoảng ta "hãy làm" cái việc "chẳng làm gì cả" đi!
Dialogue: 0,0:02:24.65,0:02:34.85,vietsub,,0,0,0,,Run-ta-ta run-ta-ta, tớ muốn ôm lấy, cả tháng ngày này và giấc mơ kia Oh Yeah!
