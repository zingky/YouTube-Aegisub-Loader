Dialogue: 0,0:00:00.45,0:00:02.25,romaji,,0,0,0,,(DADADA DANCE! DADADA DANCE!)
Dialogue: 0,0:00:02.25,0:00:03.96,romaji,,0,0,0,,Reremifafafamire
Dialogue: 0,0:00:04.07,0:00:05.75,romaji,,0,0,0,,(DADADA DANCE! DADADA DANCE!)
Dialogue: 0,0:00:05.75,0:00:07.82,romaji,,0,0,0,,Watashi ni makasete
Dialogue: 0,0:00:09.17,0:00:12.43,romaji,,0,0,0,,Ieeeeei! Isseenoo de!
Dialogue: 0,0:00:12.43,0:00:15.95,romaji,,0,0,0,,Mainichi ii koto bakka janai keredo (Nai nai!)
Dialogue: 0,0:00:15.95,0:00:19.25,romaji,,0,0,0,,Sonna toki ni wa watashi to odorimashou (iei iei)
Dialogue: 0,0:00:19.45,0:00:22.85,romaji,,0,0,0,,Tottemo suteki na keshiki ni deatta yo (nee nee)
Dialogue: 0,0:00:22.85,0:00:26.35,romaji,,0,0,0,,Mattete imasugu dareka ni misetagetai
Dialogue: 0,0:00:26.35,0:00:29.25,romaji,,0,0,0,,(DADADA DANCE! DADADA DANCE! DADADA DA DANCE!)
Dialogue: 0,0:00:29.76,0:00:32.74,romaji,,0,0,0,,Nanbyakukai demo iu kedo yuiitsu muni
Dialogue: 0,0:00:32.85,0:00:36.20,romaji,,0,0,0,,Sorezore tokui na rizumu de odorimashou
Dialogue: 0,0:00:36.20,0:00:37.85,romaji,,0,0,0,,An du torowa or 3・2・1
Dialogue: 0,0:00:37.85,0:00:43.45,romaji,,0,0,0,,Don nandemo ii kara egao o wasurenaide ne (niko)
Dialogue: 0,0:00:43.45,0:00:50.25,romaji,,0,0,0,,Toriaezu anata mo nakama ni natte tanoshimou kyou o (enjoi)
Dialogue: 0,0:00:50.25,0:00:53.50,romaji,,0,0,0,,Muzukashiku kangaenakute ii kara
Dialogue: 0,0:00:53.74,0:01:00.45,romaji,,0,0,0,,Kocchi e oide tobikondoide Oh Yeah! (An du torowa)
Dialogue: 0,0:01:00.64,0:01:03.94,romaji,,0,0,0,,Minna ga atsumatte ureshii wasshoi ii kanji!
Dialogue: 0,0:01:03.94,0:01:07.55,romaji,,0,0,0,,Zeenbu zenbu umaku iku kara hora ALL OK!
Dialogue: 0,0:01:07.55,0:01:08.98,romaji,,0,0,0,,A~i sore aiso~re
Dialogue: 0,0:01:08.98,0:01:10.82,romaji,,0,0,0,,Makechatte mo ki ni shinai
Dialogue: 0,0:01:10.85,0:01:14.66,romaji,,0,0,0,,Ima ga tobikiri koko ga suteeji
Dialogue: 0,0:01:17.33,0:01:21.22,romaji,,0,0,0,,Shunto hekonjau toki datte aru keredo (shuun)
Dialogue: 0,0:01:21.22,0:01:24.65,romaji,,0,0,0,,Tana ni agete watashi to odorimashou (rettsu dansu)
Dialogue: 0,0:01:24.65,0:01:28.06,romaji,,0,0,0,,Ganbaritai toki ganbarya ii no desu (faito)
Dialogue: 0,0:01:28.06,0:01:31.50,romaji,,0,0,0,,Aa jiyuu tte nandaka kaze mitai dane (pyuun)
Dialogue: 0,0:01:31.50,0:01:38.32,romaji,,0,0,0,,Nani mo nai nara tsukureba iinda omoi egaku you ni (iei iei)
Dialogue: 0,0:01:38.32,0:01:41.45,romaji,,0,0,0,,Donna densetsu ni mo hajimari ga aru
Dialogue: 0,0:01:41.65,0:01:44.71,romaji,,0,0,0,,Dekiru kana? Wakannai kedo!
Dialogue: 0,0:01:45.10,0:01:48.58,romaji,,0,0,0,,Chotto wa hiyotte mo tsugi wa zettai ii kanji!
Dialogue: 0,0:01:48.58,0:01:52.05,romaji,,0,0,0,,Shippai shita tte ikiteru kara giri OK
Dialogue: 0,0:01:52.05,0:01:53.70,romaji,,0,0,0,,A~i sore aiso~re
Dialogue: 0,0:01:53.70,0:01:55.50,romaji,,0,0,0,,Kattara katta de chou rakkii
Dialogue: 0,0:01:55.50,0:01:58.91,romaji,,0,0,0,,Motto saikou ashita mo saa ikou
Dialogue: 0,0:02:05.29,0:02:11.65,romaji,,0,0,0,,Runtatta runtatta kono mama suki o suki de itai dake
Dialogue: 0,0:02:11.74,0:02:18.35,romaji,,0,0,0,,Runtatta runtatta yururi to yure nagara rara
Dialogue: 0,0:02:18.35,0:02:24.65,romaji,,0,0,0,,Runtatta runtatta tama ni wa nani mo "shinai" o "shiyou"
Dialogue: 0,0:02:24.65,0:02:34.85,romaji,,0,0,0,,Runtatta runtatta aishitai konna hibi mo donna yume mo Oh Yeah!
