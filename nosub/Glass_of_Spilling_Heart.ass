Dialogue: 0,0:01:59.46,0:02:02.38,romaji,,0,0,0,,horonigai honoamai
Dialogue: 0,0:02:02.38,0:02:11.96,romaji,,0,0,0,,koboresouna omoi ga mune o mitasu
Dialogue: 0,0:02:13.62,0:02:19.58,romaji,,0,0,0,,adokenai hitomi ga
Dialogue: 0,0:02:19.58,0:02:25.33,romaji,,0,0,0,,netsu o motte kasuka ni madou
Dialogue: 0,0:02:25.33,0:02:34.19,romaji,,0,0,0,,kyou made no futari subete mou
Dialogue: 0,0:02:34.19,0:02:41.20,romaji,,0,0,0,,tobikoesou de
Dialogue: 0,0:02:44.66,0:02:50.86,romaji,,0,0,0,,honne wa aimaina mama de ii
Dialogue: 0,0:02:50.86,0:02:55.08,romaji,,0,0,0,,omotte mada tookunai
Dialogue: 0,0:02:55.08,0:03:00.38,romaji,,0,0,0,,demo sono namida
Dialogue: 0,0:03:00.38,0:03:04.88,romaji,,0,0,0,,riyuu o
Dialogue: 0,0:03:06.29,0:03:11.94,romaji,,0,0,0,,hitorijime shitai
