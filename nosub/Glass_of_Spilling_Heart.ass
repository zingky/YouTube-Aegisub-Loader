Dialogue: 0,0:01:15.13,0:01:22.28,romaji,,0,0,0,,tokekonde hikaru
Dialogue: 0,0:01:25.39,0:01:30.93,romaji,,0,0,0,,gurasu o sukashite wa mukougawa nozoita
Dialogue: 0,0:01:30.93,0:01:36.91,romaji,,0,0,0,,nagaru kumo o mesen de nazoru anata
Dialogue: 0,0:01:36.91,0:01:42.67,romaji,,0,0,0,,sekai ga kawaru hodo kirei da to omotta
Dialogue: 0,0:01:43.29,0:01:47.45,romaji,,0,0,0,,kaze fuku gogo
Dialogue: 0,0:01:47.45,0:01:50.46,romaji,,0,0,0,,tonariau kage to kage
Dialogue: 0,0:01:50.46,0:01:53.64,romaji,,0,0,0,,sotto kitai o shite
Dialogue: 0,0:01:53.64,0:01:56.46,romaji,,0,0,0,,uchikeshite machiagune
