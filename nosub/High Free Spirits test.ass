Dialogue: 0,0:02:13.97,0:02:19.23,vietsub,,0,0,0,karaoke,Hãy hét lên, tiếng thét cuối cùng, vào đại dương đau thương.
Dialogue: 0,0:02:19.15,0:02:24.35,vietsub,,0,0,0,karaoke,Thế giới rồi sẽ được tái sinh trong dòng nước mắt.
Dialogue: 0,0:02:24.27,0:02:29.41,vietsub,,0,0,0,karaoke,Giữa muôn vàn lạc lối, một tia hy vọng từ nơi xa,
Dialogue: 0,0:02:29.33,0:02:34.72,vietsub,,0,0,0,karaoke,chính là câu trả lời của sinh mệnh mong manh.
Dialogue: 0,0:02:34.64,0:02:39.88,vietsub,,0,0,0,karaoke,Hãy hét lên, tiếng thét cuối cùng, những cuộc hội ngộ rồi chia ly.
Dialogue: 0,0:02:39.80,0:02:43.89,vietsub,,0,0,0,karaoke,Chẳng thể biết kết cục rồi sẽ ra sao,
Dialogue: 0,0:02:43.81,0:02:46.19,vietsub,,0,0,0,karaoke,nhưng tớ vẫn sẽ tiến về phía trước.
Dialogue: 0,0:03:31.37,0:03:36.99,vietsub,,0,0,0,karaoke,Bình minh thắp sáng đại dương hy vọng.
Dialogue: 0,0:03:36.91,0:03:42.13,vietsub,,0,0,0,karaoke,Vạch ra ranh giới giữa hôm qua và hôm nay.
Dialogue: 0,0:03:42.05,0:03:49.55,vietsub,,0,0,0,karaoke,Chỉ cần vết tích của hải trình sinh mệnh vẫn còn kết nối,
Dialogue: 0,0:03:49.47,0:03:53.42,vietsub,,0,0,0,karaoke,nhịp đập này sẽ không ngừng lại.
Dialogue: 0,0:03:53.34,0:03:58.55,vietsub,,0,0,0,karaoke,Vang lên đi, thôi thúc mãnh liệt, đừng bao giờ phai tàn.
Dialogue: 0,0:03:58.47,0:04:03.77,vietsub,,0,0,0,karaoke,Dù mang theo những vết thương mãi không phai mờ.
Dialogue: 0,0:04:03.69,0:04:08.75,vietsub,,0,0,0,karaoke,Dư ảnh ngày xưa ấy vẫn còn đây, chẳng thể nào xóa nhòa.
Dialogue: 0,0:04:08.67,0:04:14.07,vietsub,,0,0,0,karaoke,Thế gian vẫn đang chờ, tiếng chào đời sớm mai.
Dialogue: 0,0:04:13.99,0:04:19.23,vietsub,,0,0,0,karaoke,Vang lên đi, thôi thúc mãnh liệt, vẹn nguyên không đổi thay.
Dialogue: 0,0:04:19.15,0:04:26.43,vietsub,,0,0,0,karaoke,Nơi quá khứ tương lai giao nhau, bản hùng ca trăm năm.
