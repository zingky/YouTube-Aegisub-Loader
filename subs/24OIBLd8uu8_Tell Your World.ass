Dialogue: 0,0:00:25.47,0:00:31.05,vietsub,,0,0,0,,Để không quên đi những cảm xúc vô hình vô dạng,
Dialogue: 0,0:00:31.80,0:00:38.22,vietsub,,0,0,0,,em đã xóa đi những khuôn mẫu được định sẵn.
Dialogue: 0,0:00:38.23,0:00:43.72,vietsub,,0,0,0,,Bắt lấy những giai điệu bất chợt ngân nga,
Dialogue: 0,0:00:44.66,0:00:48.63,vietsub,,0,0,0,,em đặt vào đó những lời từ đáy lòng,
Dialogue: 0,0:00:48.64,0:00:52.60,vietsub,,0,0,0,,rồi gửi chúng vào bầu trời cao.
Dialogue: 0,0:00:52.62,0:00:55.86,vietsub,,0,0,0,,Những chuyện em muốn nói với người...
Dialogue: 0,0:00:55.86,0:00:59.07,vietsub,,0,0,0,,Những điều em muốn trao cho người...
Dialogue: 0,0:00:59.07,0:01:02.24,vietsub,,0,0,0,,Vô vàn điểm nhỏ nối thành đường dài,
Dialogue: 0,0:01:02.25,0:01:05.42,vietsub,,0,0,0,,vang vọng đến phương trời xa.
Dialogue: 0,0:01:05.43,0:01:08.64,vietsub,,0,0,0,,Những câu từ em muốn gửi đến người...
Dialogue: 0,0:01:08.64,0:01:11.82,vietsub,,0,0,0,,Những thanh âm em muốn chạm đến người...
Dialogue: 0,0:01:11.87,0:01:15.04,vietsub,,0,0,0,,Muôn vàn đường dài nối thành một vòng tròn.
Dialogue: 0,0:01:15.04,0:01:17.43,vietsub,,0,0,0,,Kết nối tất cả với nhau,
Dialogue: 0,0:01:17.46,0:01:24.67,vietsub,,0,0,0,,dù ở bất cứ nơi đâu. ah ah-ah
Dialogue: 0,0:01:37.46,0:01:42.88,vietsub,,0,0,0,,Người tựa như một vầng sáng tinh khôi thuần khiết.
Dialogue: 0,0:01:43.85,0:01:50.16,vietsub,,0,0,0,,Một tiếng hát len lỏi qua kẽ tay khi em đang vươn tới.
Dialogue: 0,0:01:50.24,0:01:55.67,vietsub,,0,0,0,,Những ngón tay của em bất chợt gõ theo một nhịp điệu.
Dialogue: 0,0:01:56.63,0:02:04.64,vietsub,,0,0,0,,Em gói gọn tất cả ngôn từ, rồi gửi chúng vào bầu trời cao.
Dialogue: 0,0:02:04.64,0:02:07.85,vietsub,,0,0,0,,Những chuyện em muốn nói với người...
Dialogue: 0,0:02:07.85,0:02:11.03,vietsub,,0,0,0,,Những điều em muốn trao cho người...
Dialogue: 0,0:02:11.06,0:02:14.24,vietsub,,0,0,0,,Vô vàn điểm nhỏ nối thành đường dài,
Dialogue: 0,0:02:14.24,0:02:17.43,vietsub,,0,0,0,,xuyên đến tận phương trời xa.
Dialogue: 0,0:02:17.43,0:02:20.65,vietsub,,0,0,0,,Những câu từ em muốn gửi đến người...
Dialogue: 0,0:02:20.65,0:02:23.84,vietsub,,0,0,0,,Những thanh âm em muốn chạm đến người...
Dialogue: 0,0:02:23.88,0:02:27.06,vietsub,,0,0,0,,Muôn vàn đường dài nối thành một vòng tròn.
Dialogue: 0,0:02:27.07,0:02:29.46,vietsub,,0,0,0,,Kết nối tất cả với nhau,
Dialogue: 0,0:02:29.46,0:02:36.47,vietsub,,0,0,0,,dù ở bất cứ nơi đâu. ah ah-ah
Dialogue: 0,0:02:36.83,0:02:42.98,vietsub,,0,0,0,,Ah-ah ah ah-ah-ah
Dialogue: 0,0:02:43.02,0:02:49.46,vietsub,,0,0,0,,Em đã từng chẳng hoài nghi, cứ sống trong tháng ngày chẳng đổi thay.
Dialogue: 0,0:02:49.66,0:02:55.63,vietsub,,0,0,0,,Em đã nghĩ bình minh là thứ ai đó ban tặng cho mình.
Dialogue: 0,0:02:55.86,0:03:02.26,vietsub,,0,0,0,,Dù chỉ thoáng qua, thanh âm em tin tưởng, đang làm lay động đất trời.
Dialogue: 0,0:03:02.46,0:03:11.36,vietsub,,0,0,0,,Hãy cho em biết về thế giới của riêng người.
Dialogue: 0,0:03:11.82,0:03:15.04,vietsub,,0,0,0,,Những chuyện người muốn nói ra...
Dialogue: 0,0:03:15.04,0:03:18.26,vietsub,,0,0,0,,Những điều người muốn trao đi...
Dialogue: 0,0:03:18.27,0:03:21.45,vietsub,,0,0,0,,Vô vàn điểm nhỏ nối thành đường dài,
Dialogue: 0,0:03:21.46,0:03:24.64,vietsub,,0,0,0,,vang vọng đến phương trời xa.
Dialogue: 0,0:03:24.64,0:03:27.85,vietsub,,0,0,0,,Những câu từ người muốn gửi đến...
Dialogue: 0,0:03:27.85,0:03:31.05,vietsub,,0,0,0,,Những thanh âm người muốn vang xa...
Dialogue: 0,0:03:31.06,0:03:34.24,vietsub,,0,0,0,,Muôn vàn đường dài nối thành một vòng tròn.
Dialogue: 0,0:03:34.24,0:03:36.60,vietsub,,0,0,0,,Gắn kết mọi thứ với nhau,
Dialogue: 0,0:03:36.66,0:03:44.46,vietsub,,0,0,0,,dù ở bất cứ nơi đâu. ah ah-ah
Dialogue: 0,0:03:44.84,0:03:55.07,vietsub,,0,0,0,,Ah-ah-ah-ah ah-ah
