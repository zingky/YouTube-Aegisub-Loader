Dialogue: 0,0:00:12.89,0:00:24.74,vietsub,,0,0,0,,đã sớm tan vào bầu trời, tựa pháo hoa trên cao.
Dialogue: 0,0:00:29.14,0:00:32.70,vietsub,,0,0,0,,Hương thơm từ mái tóc của cậu lan toả.
Dialogue: 0,0:00:32.70,0:00:36.23,vietsub,,0,0,0,,Dáng cậu mặc yukata sao thật rạng rỡ.
Dialogue: 0,0:00:36.23,0:00:43.24,vietsub,,0,0,0,,Trong đêm lễ hội, cứ làm con tim tớ rộn ràng.
Dialogue: 0,0:00:43.24,0:00:46.78,vietsub,,0,0,0,,Giữa dòng người đông đúc như sắp lạc mất nhau.
Dialogue: 0,0:00:46.78,0:00:50.35,vietsub,,0,0,0,,"Đừng rời xa tớ nhé", tớ định đưa tay ra nói thế,
Dialogue: 0,0:00:50.35,0:00:57.74,vietsub,,0,0,0,,nhưng lại nắm chặt tay, rồi giấu vào trong túi áo.
Dialogue: 0,0:00:57.84,0:01:04.85,vietsub,,0,0,0,,Mùa hè có cậu ở bên, ở trong giấc mộng xa vời,
Dialogue: 0,0:01:04.85,0:01:12.24,vietsub,,0,0,0,,đã sớm tan vào bầu trời, tựa pháo hoa trên cao.
Dialogue: 0,0:01:16.80,0:01:20.38,vietsub,,0,0,0,,Cậu như một đứa trẻ khi vớt cá vàng vậy.
Dialogue: 0,0:01:20.38,0:01:23.88,vietsub,,0,0,0,,Cậu chìm đắm đến ướt cả tay áo.
Dialogue: 0,0:01:23.88,0:01:30.94,vietsub,,0,0,0,,Góc nghiêng hồn nhiên của cậu trông đáng yêu lắm.
Dialogue: 0,0:01:30.94,0:01:34.45,vietsub,,0,0,0,,Cậu đã mua kẹo bông mà cậu thích rồi.
Dialogue: 0,0:01:34.45,0:01:38.02,vietsub,,0,0,0,,1Đang vui vẻ vậy mà, ngay ở phía đằng xa,
Dialogue: 0,0:01:38.02,0:01:45.24,vietsub,,0,0,0,,cậu nhìn thấy đám bạn, rồi cứ thế rời xa tớ.
Dialogue: 0,0:01:45.49,0:01:52.50,vietsub,,0,0,0,,Mùa hè có cậu ở bên, ở trong giấc mộng xa vời,
Dialogue: 0,0:01:52.50,0:01:59.74,vietsub,,0,0,0,,đã sớm tan vào bầu trời, tựa pháo hoa trên cao.
Dialogue: 0,0:02:52.10,0:02:55.65,vietsub,,0,0,0,,Ngồi trên bậc thang ở trong đền thờ.
Dialogue: 0,0:02:55.65,0:02:59.16,vietsub,,0,0,0,,Giữa màn đêm mờ ảo tối tăm.
Dialogue: 0,0:02:59.16,0:03:06.19,vietsub,,0,0,0,,Thanh âm của lễ hội, vang vọng từ phía xa.
Dialogue: 0,0:03:06.19,0:03:09.78,vietsub,,0,0,0,,Châm một que diêm thắp sáng pháo hoa trên tay.
Dialogue: 0,0:03:09.78,0:03:13.26,vietsub,,0,0,0,,Chúng ta đã chuyện trò với nhau bao điều.
Dialogue: 0,0:03:13.26,0:03:21.24,vietsub,,0,0,0,,Vậy mà câu tớ thích cậu, lại chẳng thể nói ra.
