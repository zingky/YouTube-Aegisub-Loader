Dialogue: 0,0:00:38.34,0:00:40.11,vietsub,,0,0,0,,Mùi hương mùa hạ cứ dai dẳng bám theo.
Dialogue: 0,0:00:40.29,0:00:42.73,vietsub,,0,0,0,,Tớ chẳng muốn quên, nhưng dẫu vậy...
Dialogue: 0,0:00:43.69,0:00:47.61,vietsub,,0,0,0,,Xin người hãy kết liễu đi, hãy tước đi tất cả.
Dialogue: 0,0:00:48.10,0:00:52.22,vietsub,,0,0,0,,Hãy cắn xé những cô độc và nỗi đau,
Dialogue: 0,0:00:48.10,0:00:52.22,vietsub - Sao chép,,0,0,0,,đến khi úa tàn.
Dialogue: 0,0:00:52.24,0:00:55.47,vietsub,,0,0,0,,Với thứ tình yêu đẹp đẽ đến điên cuồng.
Dialogue: 0,0:00:55.90,0:01:01.89,vietsub,,0,0,0,,Hãy đoạt lấy những yếu đuối và tuyệt vọng,
Dialogue: 0,0:00:55.90,0:01:01.89,vietsub - Sao chép,,0,0,0,,ban cho tớ ước nguyện.
Dialogue: 0,0:01:07.58,0:01:12.09,vietsub,,0,0,0,,Đã từng, có lúc, rực rỡ...đến chói lòa.
Dialogue: 0,0:01:12.47,0:01:14.98,vietsub,,0,0,0,,Nhưng con tim vốn đã chìm xuống.
Dialogue: 0,0:01:15.40,0:01:17.87,vietsub,,0,0,0,,Hơi thở, cứ thế, dừng lại.
Dialogue: 0,0:01:18.35,0:01:21.92,vietsub,,0,0,0,,Những ký ức giờ đây đã
Dialogue: 0,0:01:18.35,0:01:21.92,vietsub - Sao chép,,0,0,0,,nhuộm lấy con tim tớ.
Dialogue: 0,0:01:23.46,0:01:26.69,vietsub,,0,0,0,,Ước nguyện tớ chôn giấu sẽ chẳng thể
Dialogue: 0,0:01:23.46,0:01:26.69,vietsub - Sao chép,,0,0,0,,chạm tới.
Dialogue: 0,0:01:27.10,0:01:30.55,vietsub,,0,0,0,,Vì lời hứa chẳng thể giữ cũng chỉ là
Dialogue: 0,0:01:27.10,0:01:30.55,vietsub - Sao chép,,0,0,0,,dối trá.
Dialogue: 0,0:01:31.26,0:01:33.63,vietsub,,0,0,0,,Hãy nhớ lại đi, bản chất thật của cậu.
Dialogue: 0,0:01:33.96,0:01:39.51,vietsub,,0,0,0,,Hãy cười với tớ, giống như ngày hôm đó.
Dialogue: 0,0:01:54.63,0:01:58.16,vietsub,,0,0,0,,Giọng nói không phai, hơi ấm ấy,
Dialogue: 0,0:01:54.63,0:01:58.16,vietsub - Sao chép,,0,0,0,,ánh chiều tà, tiếng sóng gào.
Dialogue: 0,0:01:58.35,0:02:00.88,vietsub,,0,0,0,,Vẫn đang níu giữ trái tim này.
Dialogue: 0,0:02:01.75,0:02:04.20,vietsub,,0,0,0,,Có phải tất cả sẽ chấm dứt
Dialogue: 0,0:02:04.20,0:02:08.13,vietsub,,0,0,0,,bằng chính đôi tay này?
Dialogue: 0,0:02:09.56,0:02:11.50,vietsub,,0,0,0,,Tớ căm hận cái ngày mai hy vọng,
Dialogue: 0,0:02:11.63,0:02:18.13,vietsub,,0,0,0,,nên tất cả là giả dối cũng được thôi.
Dialogue: 0,0:02:19.29,0:02:23.31,vietsub,,0,0,0,,Cậu ơi, hãy cho tớ được toại nguyện,
Dialogue: 0,0:02:19.29,0:02:23.31,vietsub - Sao chép,,0,0,0,,xin hãy xé nát thân xác này.
Dialogue: 0,0:02:23.69,0:02:27.84,vietsub,,0,0,0,,Bằng đôi tay ấy, bằng ham muốn ấy,
Dialogue: 0,0:02:23.69,0:02:27.84,vietsub - Sao chép,,0,0,0,,hãy làm tớ thoả mãn.
Dialogue: 0,0:02:27.90,0:02:31.08,vietsub,,0,0,0,,Hãy đưa tớ đến tận cùng cuộc đời tươi đẹp,
Dialogue: 0,0:02:31.50,0:02:34.23,vietsub,,0,0,0,,rồi nuốt trọn máu thịt lẫn tâm can.
Dialogue: 0,0:02:34.67,0:02:37.67,vietsub,,0,0,0,,Hãy thực hiện đi !
Dialogue: 0,0:02:42.25,0:02:45.70,vietsub,,0,0,0,,Chỉ thêm một chút nữa thôi, hãy đợi nhé...
Dialogue: 0,0:02:50.05,0:02:51.56,vietsub,,0,0,0,,Nguyện ước của tớ,
Dialogue: 0,0:02:52.02,0:02:53.48,vietsub,,0,0,0,,vỏn vẹn, chỉ là...
